# Managed by Ansible — do not edit manually
# Role: linux_hardening | Template: sshd_config.j2

Port {{ ssh_port }}
AddressFamily inet
ListenAddress 0.0.0.0

# Host keys (only modern algorithms)
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key

# Authentication
PermitRootLogin {{ ssh_permit_root_login }}
MaxAuthTries {{ ssh_max_auth_tries }}
MaxSessions 4
LoginGraceTime {{ ssh_login_grace_time }}

PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
PasswordAuthentication {{ ssh_password_authentication }}
ChallengeResponseAuthentication {{ ssh_challenge_response_authentication }}
UsePAM yes

# Forwarding & environment
X11Forwarding {{ ssh_x11_forwarding }}
AllowAgentForwarding no
AllowTcpForwarding no
PermitTunnel no
PrintMotd yes
Banner {{ ssh_banner }}

# Session keepalive
ClientAliveInterval {{ ssh_client_alive_interval }}
ClientAliveCountMax {{ ssh_client_alive_count_max }}

# Restrict users
{% if ssh_allowed_users is defined %}
AllowUsers {{ ssh_allowed_users }}
{% endif %}

# Ciphers and MACs (modern only)
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org

# Subsystems
Subsystem sftp /usr/lib/openssh/sftp-server
